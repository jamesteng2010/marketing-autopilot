{
  "$schema": "internal/marketing-autopilot-credentials/v1",
  "channels": {
    "aws": {
      "label": "Amazon Web Services",
      "required": ["AWS_ACCESS_KEY_ID", "AWS_SECRET_ACCESS_KEY", "AWS_REGION"],
      "optional": ["AWS_SESSION_TOKEN"],
      "when": "Deploying EC2, S3 assets, or SES email",
      "storeIn": "cursor_secrets_or_iam_role"
    },
    "stripe": {
      "label": "Stripe",
      "required": ["STRIPE_SECRET_KEY"],
      "optional": ["STRIPE_WEBHOOK_SECRET", "STRIPE_PUBLISHABLE_KEY"],
      "when": "Payment pages, checkout tests, subscription funnels",
      "storeIn": "cursor_secrets"
    },
    "telegram": {
      "label": "Telegram user API",
      "required": ["TELEGRAM_API_ID", "TELEGRAM_API_HASH", "TELEGRAM_SESSION"],
      "optional": ["TELEGRAM_BOT_TOKEN", "TELEGRAM_CHAT_ID"],
      "when": "DM outreach, group monitoring, channel posts",
      "storeIn": "cursor_secrets_never_git"
    },
    "smtp": {
      "label": "Email (SMTP)",
      "required": ["SMTP_HOST", "SMTP_USER", "SMTP_PASS"],
      "optional": ["SMTP_FROM"],
      "when": "Reports, drip email, notifications",
      "storeIn": "cursor_secrets"
    },
    "openai": {
      "label": "OpenAI / LLM",
      "required": ["OPENAI_API_KEY"],
      "optional": [],
      "when": "Copy generation, conversation agents",
      "storeIn": "cursor_secrets"
    },
    "meta": {
      "label": "Meta (Facebook / Instagram ads)",
      "required": ["META_ACCESS_TOKEN", "META_AD_ACCOUNT_ID"],
      "optional": ["META_PIXEL_ID"],
      "when": "Paid social or pixel setup",
      "storeIn": "cursor_secrets"
    },
    "google_ads": {
      "label": "Google Ads",
      "required": ["GOOGLE_ADS_CLIENT_ID", "GOOGLE_ADS_CLIENT_SECRET", "GOOGLE_ADS_REFRESH_TOKEN"],
      "optional": ["GOOGLE_ADS_CUSTOMER_ID"],
      "when": "Search / display campaigns",
      "storeIn": "cursor_secrets"
    },
    "phone_sms": {
      "label": "SMS / voice (Twilio etc.)",
      "required": ["TWILIO_ACCOUNT_SID", "TWILIO_AUTH_TOKEN", "TWILIO_PHONE_NUMBER"],
      "optional": [],
      "when": "SMS verification or outreach (with consent)",
      "storeIn": "cursor_secrets"
    }
  },
  "rules": [
    "Never commit secret values to git",
    "Ask user for credentials only when a registered task requires that channel",
    "Record requested keys in intake/active.json credentialsRequested array",
    "Record satisfied keys (names only) in credentialsProvided — not values"
  ]
}
