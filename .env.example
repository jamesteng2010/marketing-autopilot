# Copy to .env.local (never commit)
# Dev infra: docs/infrastructure/aws-dev-environment.md
# DB detail: docs/infrastructure/database.md
# Passwords: secrets.local.env (see secrets.local.env.example)

# --- Platform API (v0.2) ---
PORT=3001
WORKSPACE_ROOT=projects

# MySQL on Kids Guard Prod — use SSH tunnel locally:
#   ssh -i ~/.ssh/kids-guard-prod.pem -L 13306:127.0.0.1:3306 ubuntu@54.206.252.93 -N
DB_HOST=127.0.0.1
DB_PORT=13306
DB_NAME=marketing-autopilot-dev
DB_USER=marketing-autopilot
DB_PASS=CHANGE_ME
DATABASE_URL=mysql://marketing-autopilot:CHANGE_ME@127.0.0.1:13306/marketing-autopilot-dev

# --- Orchestrator / Worker context ---
USER_ID=dev-user-001
PROJECT_ID=marketing-autopilot-launch
PROJECT_ROOT=projects/marketing-autopilot-launch
CORRELATION_ID=

# --- Cursor Automation webhooks ---
# CURSOR_AUTOMATION_05_WEBHOOK_URL=

# --- Dev public URLs (EC2) ---
# MA_PUBLIC_URL=https://myreceipt.website
# MA_API_URL=https://api.myreceipt.website

# Cursor Automations (optional — see infra/automations/SETUP.md)
# CURSOR_AUTOMATION_05_WEBHOOK_URL=https://...
# AUTOMATION_CALLBACK_TOKEN=generate-a-long-random-string

# Server-side analysis Phase B (recommended on EC2; used when webhook not set or OpenAI preferred)
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Channel secrets (prefer Cursor Automation Secrets in production)
# TELEGRAM_API_ID=
# TELEGRAM_API_HASH=
# TELEGRAM_SESSION=
# STRIPE_SECRET_KEY=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=
# SMTP_HOST=
# SMTP_USER=
# SMTP_PASS=
