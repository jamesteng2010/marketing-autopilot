# Platform API — EC2 / local (copy to .env on server; local uses repo root .env.local values)
PORT=3002
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=marketing-autopilot-dev
DB_USER=marketing-autopilot
DB_PASS=change-me
JWT_SECRET=change-me-long-random-string
JWT_EXPIRES_IN=7d
WORKSPACE_ROOT=/opt/marketing-autopilot/projects

APP_PUBLIC_URL=https://api.myreceipt.website
MAIL_FROM=noreply@myreceipt.website
MAIL_FROM_NAME=Marketing Autopilot
MAIL_REPLY_TO=noreply@myreceipt.website
MAIL_PRODUCT_NAME=Marketing Autopilot
MAIL_DEV_LOG=false

AWS_REGION=ap-southeast-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
